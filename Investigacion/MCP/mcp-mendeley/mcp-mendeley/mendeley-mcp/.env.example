# ================================================
# MENDELEY MCP SERVER - CONFIGURACIÓN
# ================================================
# 1. Ve a https://dev.mendeley.com/myapps.html
# 2. Crea una nueva aplicación
# 3. Copia el Client ID y Client Secret aquí
# 4. En Redirect URIs pon: http://localhost:3333/callback

MENDELEY_CLIENT_ID=tu_client_id_aqui
MENDELEY_CLIENT_SECRET=tu_client_secret_aqui
MENDELEY_REDIRECT_URI=http://localhost:3333/callback

# Este token se genera automáticamente al correr: npm run auth
MENDELEY_ACCESS_TOKEN=
MENDELEY_REFRESH_TOKEN=
